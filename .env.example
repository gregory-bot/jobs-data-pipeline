# ============================================
# Frontend / Site Configuration
# ============================================
FRONTEND_URL=https://careers.annex-technologies.com
SITE_URL=https://careers.annex-technologies.com
BACKEND_URL=https://api.annex-technologies.com  # Update with your API domain

# ============================================
# Database Configuration
# ============================================
DB_HOST=your-db-host.com
DB_PORT=5432
DB_NAME=jobs_pipeline
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSLMODE=require

# ============================================
# Email Service Configuration
# ============================================
# Option 1: Brevo (Recommended for production)
BREVO_API_KEY=your-brevo-api-key

# Option 2: Resend
RESEND_API_KEY=your-resend-api-key

# Option 3: SMTP (Gmail, Mailgun, etc.)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=noreply@annex-technologies.com
EMAIL_FROM_NAME=Annex Careers

# ============================================
# Scraper Configuration
# ============================================
SCRAPE_INTERVAL_HOURS=24
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ============================================
# Airflow Configuration
# ============================================
AIRFLOW_HOME=/path/to/airflow_home
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_FOLDER=/path/to/airflow_home/dags
