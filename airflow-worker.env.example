# Example .env file for Airflow worker on Render
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<user>:<password>@<host>:<port>/<db>?sslmode=require
AIRFLOW__CORE__FERNET_KEY=REPLACE_ME_WITH_A_REAL_KEY
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=REPLACE_ME_WITH_A_REAL_SECRET
DB_HOST=<host>
DB_PORT=<port>
DB_NAME=<db>
DB_USER=<user>
DB_PASSWORD=<password>
DB_SSLMODE=require
